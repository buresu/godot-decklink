config_version=5

[application]

config/name="godot-decklink demo"
run/main_scene="res://scenes/decklink_demo.tscn"
config/features=PackedStringArray("4.6")

[native_extensions]

paths=["res://addons/godot-decklink/godot-decklink.gdextension"]

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
