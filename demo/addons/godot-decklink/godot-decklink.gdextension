[configuration]
entry_symbol = "godot_decklink_init"
compatibility_minimum = "4.3"
reloadable = false

[libraries]
windows.debug.x86_64   = "res://addons/godot-decklink/bin/libgodot-decklink.windows.debug.x86_64.dll"
windows.release.x86_64 = "res://addons/godot-decklink/bin/libgodot-decklink.windows.release.x86_64.dll"
windows.debug.arm64    = "res://addons/godot-decklink/bin/libgodot-decklink.windows.debug.arm64.dll"
windows.release.arm64  = "res://addons/godot-decklink/bin/libgodot-decklink.windows.release.arm64.dll"

macos.debug.x86_64     = "res://addons/godot-decklink/bin/libgodot-decklink.macos.debug.x86_64.dylib"
macos.release.x86_64   = "res://addons/godot-decklink/bin/libgodot-decklink.macos.release.x86_64.dylib"
macos.debug.arm64      = "res://addons/godot-decklink/bin/libgodot-decklink.macos.debug.arm64.dylib"
macos.release.arm64    = "res://addons/godot-decklink/bin/libgodot-decklink.macos.release.arm64.dylib"

linux.debug.x86_64     = "res://addons/godot-decklink/bin/libgodot-decklink.linux.debug.x86_64.so"
linux.release.x86_64   = "res://addons/godot-decklink/bin/libgodot-decklink.linux.release.x86_64.so"
linux.debug.arm64      = "res://addons/godot-decklink/bin/libgodot-decklink.linux.debug.arm64.so"
linux.release.arm64    = "res://addons/godot-decklink/bin/libgodot-decklink.linux.release.arm64.so"
